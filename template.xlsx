<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign in · Operations Platform</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/static/css/design-tokens.css">
    <link rel="stylesheet" href="/static/css/auth.css">
</head>
<body class="auth-page">
    <main class="auth-shell">
        <section class="auth-panel auth-panel--visual d-none d-lg-flex">
            <div class="auth-visual__glow"></div>
            <div class="auth-visual__grid"></div>
            <div class="auth-visual__content">
                <span class="eyebrow text-white text-uppercase letter-spacing">Enterprise Operations</span>
                <h1 class="display-6 text-white fw-bold mt-3">Manage Your Operations</h1>
                <p class="text-muted mt-3">Enterprise fleet, workforce and operations management simplified with secure, scalable control.</p>
                <div class="auth-visual__stats mt-5">
                    <div>
                        <strong>98%</strong>
                        <span>Uptime coverage</span>
                    </div>
                    <div>
                        <strong>2.3M</strong>
                        <span>Daily tasks tracked</span>
                    </div>
                </div>
            </div>
            <div class="auth-visual__illustration" aria-hidden="true">
                <div class="hero-card">
                    <div class="hero-card__panel"></div>
                    <div class="hero-card__line hero-card__line--one"></div>
                    <div class="hero-card__line hero-card__line--two"></div>
                    <div class="hero-card__icon"></div>
                </div>
            </div>
        </section>

        <section class="auth-panel auth-panel--form bg-white shadow-sm rounded-4">
            <div class="auth-card shadow-sm rounded-4 p-4 p-md-5">
                <div class="auth-form__header text-center mb-4">
                    <div class="brand-mark mb-3">VIL</div>
                    <h2 class="h4 fw-semibold">Welcome Back</h2>
                    <p class="text-soft">Secure access to your operations dashboard.</p>
                </div>
                
                
                

                <form id="authForm" class="needs-validation" method="POST" action="/login" novalidate>
                    <input id="csrf_token" name="csrf_token" type="hidden" value="ImQ3NjhjMjA4MDk2ODViNDYyZjk2Njc4NDdiZDcyZGYxZDM0NWZlZDMi.ajUWgA.r0VPoefJnTVWQ3JFZjmFWNQtdfc">
                    
                        <input type="hidden" name="next" value="/user-management/bulk-import/template">
                    
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control form-control-lg" id="loginIdentifier" name="login_identifier" placeholder="Email or Username" required autocomplete="username">
                        <label for="loginIdentifier">Email or Username</label>
                        <div class="invalid-feedback">Enter your email or username.</div>
                    </div>

                    <div class="form-floating mb-3 position-relative">
                        <input type="password" class="form-control form-control-lg" id="loginPassword" name="password" placeholder="Password" required autocomplete="current-password" aria-describedby="passwordHelp">
                        <label for="loginPassword">Password</label>
                        <button type="button" class="password-toggle" aria-label="Show password" id="togglePassword">
                            <span class="material-symbols-outlined">visibility</span>
                        </button>
                        <div class="invalid-feedback">Password is required.</div>
                    </div>

                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe" name="remember_me">
                            <label class="form-check-label text-soft" for="rememberMe">Remember me</label>
                        </div>
                        <a href="/forgot-password" class="text-decoration-none text-muted small">Forgot password?</a>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg btn-gradient w-100 position-relative" id="loginButton">
                        <span class="btn-text">Sign in securely</span>
                        <span class="spinner-border spinner-border-sm text-white d-none" role="status" aria-hidden="true" id="authSpinner"></span>
                    </button>

                    <div class="separator my-4 text-center text-soft">or continue with</div>
                    <button type="button" class="btn btn-outline-secondary btn-lg w-100 d-flex align-items-center justify-content-center gap-2" disabled>
                        <span class="material-symbols-outlined">verified_user</span>
                        Single Sign-On (SSO)
                    </button>
                </form>

                <p class="text-center text-soft mt-4 small">Session timeout is tracked automatically for secure access and audit compliance.</p>
            </div>
        </section>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/static/js/auth.js"></script>
</body>
</html>